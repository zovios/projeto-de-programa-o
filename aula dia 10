        "# Escrever um programa que leia o valor da compra e explique\n",
        "\n",
        "# até R$ 100 - sem desconto\n",
        "# até R$ 101 - 10% de desconto\n",
        "# acima de R$500 - 20% de desconto\n",
        "\n",
        "# mostrar o valor a pagar depois de aplicado o desconto\n",
        "\n",
        "# variavel\n",
        "\n",
        "compra = float (input(\"digite um valor: \"))\n",
        "\n",
        "desconto = compra - (compra * 0.10)\n",
        "\n",
        "if compra > 100:\n",
        "  desconto = compra - (compra * 0.10)\n",
        "  print (f\"o valor a pagar é : {desconto}\")\n",
        "\n",
        "elif compra > 500:\n",
        "  desconto = compra - (compra * 0.20)\n",
        "  print (f\"o valor a pagar é : {desconto}\")\n",
        "\n",
        "else:\n",
        "  print (f\"voce não obteve desconto, valor a pagar : {compra}\")"
