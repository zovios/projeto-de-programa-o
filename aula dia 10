        "elif compra > 500:\n",
        "  desconto = compra - (compra * 0.20)\n",
        "  print (f\"o valor a pagar é : {desconto}\")\n",
        "\n",
        "else:\n",
        "  print (f\"voce não obteve desconto, valor a pagar : {compra}\")"
